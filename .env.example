# ──────────────────────────────────────────────────────────────
# Image Pipeline Configuration
# ──────────────────────────────────────────────────────────────
# Choose one: "cloudflare" | "supabase" | "cloudinary" | comma-separated for fallback chain (e.g. "supabase,cloudinary")
VITE_IMAGE_PROVIDER= 

# ── Cloudflare R2 ─────────────────────────────────────────────
VITE_CF_R2_ACCOUNT_ID=
VITE_CF_R2_BUCKET=profile-images
VITE_CF_R2_ACCESS_KEY_ID=
VITE_CF_R2_SECRET_ACCESS_KEY=
VITE_CF_R2_PUBLIC_URL=

# ── Supabase Storage ──────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_BUCKET=profile-images

# ── Cloudinary ────────────────────────────────────────────────
VITE_CLOUDINARY_CLOUD_NAME=cn5hh5ox
VITE_CLOUDINARY_UPLOAD_PRESET=LinkedIn-Scrapper
